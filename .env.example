# TeamMember
# Copy to .env then run: docker compose up -d --build

# DashScope (Qwen) - vision + embedding
DASHSCOPE_API_KEY=
DASHSCOPE_VISION_MODEL=qwen-vl-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2
# Optional: vector dim for the embedding model (text-embedding-v2 is commonly 1536)
QDRANT_VECTOR_SIZE=1536

# Volcengine Ark (OpenAI-compatible chat) - chunking + chat + memory
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CHAT_MODEL=deepseek-v3-2-251201
ARK_TEMPERATURE=0.2

# Qdrant
QDRANT_KNOWLEDGE_COLLECTION=tm_knowledge
QDRANT_MEMORY_COLLECTION=tm_user_memory
QDRANT_DISTANCE=cosine

# PostgreSQL
POSTGRES_DB=teammember
POSTGRES_USER=teammember
POSTGRES_PASSWORD=teammember_password_change_me
DATABASE_URL=postgresql+psycopg://teammember:teammember_password_change_me@postgres:5432/teammember

# Optional: images (if Docker Hub is blocked, point to your mirror registry)
POSTGRES_IMAGE=postgres:16-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.9.5

# Optional: base images for builds (if Docker Hub is blocked, use a mirror)
# Example:
# PYTHON_BASE_IMAGE=m.daocloud.io/library/python:3.11-slim
# NODE_BASE_IMAGE=m.daocloud.io/library/node:20-alpine
# NGINX_BASE_IMAGE=m.daocloud.io/library/nginx:1.27-alpine
PYTHON_BASE_IMAGE=python:3.11-slim
NODE_BASE_IMAGE=node:20-alpine
NGINX_BASE_IMAGE=nginx:1.27-alpine

# Optional: package mirrors (when pip/npm is blocked)
# Example:
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
# NPM_REGISTRY=https://registry.npmmirror.com
PIP_INDEX_URL=
PIP_TRUSTED_HOST=
NPM_REGISTRY=

# Auth
AUTH_ENABLED=true
JWT_SECRET=change_me_in_production
JWT_EXP_MINUTES=10080

# RAG policy
# auto | force_on | force_off
RAG_POLICY=auto
RAG_TOP_K=10
RAG_MAX_CONTEXT=12
# Only use rerank when knowledge docs >= this threshold (0 disables)
RAG_RERANK_MIN_DOCS=8000
# Boost approved Teaching seeds (source_kind=teaching) in similarity ordering
RAG_TEACHING_SCORE_BOOST=0.05
# Ensure we pull at least this many candidates before applying Teaching boost
RAG_TEACHING_CANDIDATES=40

# Thread state (semantic triggers)
THREAD_STATE_ENABLED=true
THREAD_STATE_WINDOW_MSGS=60
THREAD_STATE_COOLDOWN_SECONDS=90

# Decision profile (how a user decides/verifies/assumes)
DECISION_PROFILE_ENABLED=true
# Refreshed during idle time by a backend maintenance thread (default ~03:15 local time).
DECISION_PROFILE_REFRESH_HOURS=120

# Memory (persona + long-term memory)
MEMORY_ENABLED=true
MEMORY_TOP_K=5

# Topic guard (optional scope control)
# When enabled, the assistant will try to stay inside TOPIC_ALLOWED_TOPICS unless a user has "话题例外".
TOPIC_GUARD_ENABLED=false
TOPIC_ALLOWED_TOPICS=21V Microsoft 365（世纪互联）及相关的 Power Platform / Dynamics 365

# Web search (Bing, optional)
# If BING_SEARCH_API_KEY is empty, web search will be disabled even if WEB_SEARCH_ENABLED=true.
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
BING_SEARCH_MARKET=zh-CN
BING_SEARCH_SAFE_SEARCH=Moderate
WEB_SEARCH_ENABLED=false
WEB_SEARCH_TOP_K=5
WEB_SEARCH_MAX_QUERIES=2

# Sub-agent decomposition (optional)
# auto | force_on | force_off
AGENT_DECOMPOSE_POLICY=auto
# 0..100 (higher => decompose more often)
AGENT_DECOMPOSE_BIAS=30
AGENT_MAX_SUBTASKS=5

# Privacy
# Whether to allow users to ask the assistant to show internal Persona/Decision summaries inside a shared thread.
# Recommended: keep false in production. (Admin UI can also override at runtime.)
PERSONA_DISCLOSURE_ENABLED=false

# AI trace (routing/tools/sub-agents)
AI_TRACE_ENABLED=true
# Keep traces for N days (daily cleanup)
AI_TRACE_RETENTION_DAYS=30

# Proactive nudge (optional)
# When enabled, during work time the assistant may add a short proactive line for heavy users.
PROACTIVE_ENABLED=false
PROACTIVE_MIN_USER_MSGS=500
PROACTIVE_WEEKDAY_ONLY=true
PROACTIVE_WORK_START=09:00
PROACTIVE_WORK_END=18:00
PROACTIVE_TIMEZONE=Asia/Shanghai

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
