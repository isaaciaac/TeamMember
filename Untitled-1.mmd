
flowchart TD
  %% TeamMember Architecture (updated: deep thinking 5 roles + SSE meta + trace learning)

  %% =======================
  %% Frontend
  %% =======================
  subgraph FE[前端（React/Vite + Nginx）]
    browser[浏览器]
    ui[TeamMember Web App]
  end

  %% =======================
  %% Backend
  %% =======================
  subgraph BE[后端（FastAPI）]
    settingsPy[settings.py（BaseSettings from .env）]
    runtimeCfg[runtime_config（TTL=3s；app_config 覆盖）]

    auth[Auth/JWT]
    threadAPI[Threads & Shares API]
    chatAPI[POST /threads/:id/chat_stream（SSE: delta + meta）]
    msgAPI[GET /threads/:id/messages]
    traceAPI[GET /threads/:id/messages/:mid/trace]

    adminAPI[Admin API（用户/配置/审核/审计/Trace Insights）]
    ingestAPI[Knowledge Ingest & Teaching API]
    visionAPI[POST /vision/describe]

    guards[Guardrails（系统提示词/画像披露/注入拦截）]
    ctx[Context Builder（profile/persona/decision/memory）]
    tstate[Thread State（open loops / entropy）]

    router[Intent Router（decide_rag）]
    deep[Deep Thinking Orchestrator（固定 5 角色）]
    roles[Role Agents（发散/证据/质疑/收敛/沟通稿）]

    ragTool[RAG Retriever（Qdrant）]
    webTool[Web Search Tool（Bing 摘要）]
    synth[Final Answer Generator（Ark stream）]

    traceLearn[AI Trace Learning（Level 2，仅建议）]

    bg[Background Tasks（memory/persona/thread_state）]
    maint[Maintenance Thread（03:15 daily）]
  end

  %% =======================
  %% Storage
  %% =======================
  subgraph ST[存储]
    env[.env（启动时读取）]
    pg[(PostgreSQL)]
    appcfg[(app_config 运行时覆盖)]
    audit[(audit_logs 只增不改 + hash chain)]
    traceTbl[(ai_trace_runs（30天保留）)]
    insightTbl[(ai_trace_insights（建议，不自动生效）)]
    qdr[(Qdrant：tm_knowledge / tm_user_memory)]
  end

  %% =======================
  %% External Services
  %% =======================
  subgraph EXT[外部服务]
    ark[(Volcengine Ark / DeepSeek)]
    dashEmb[(DashScope Embedding)]
    dashVision[(DashScope Vision)]
    bing[(Bing Search API)]
  end

  %% =======================
  %% Wiring: UI -> API
  %% =======================
  browser --> ui
  ui --> auth
  ui --> threadAPI
  ui --> chatAPI
  ui --> msgAPI
  ui --> traceAPI
  ui --> adminAPI
  ui --> ingestAPI
  ui --> visionAPI

  %% =======================
  %% Config: .env + app_config
  %% =======================
  env --> settingsPy
  settingsPy --> runtimeCfg
  appcfg --> runtimeCfg

  runtimeCfg --> router
  runtimeCfg --> ragTool
  runtimeCfg --> webTool
  runtimeCfg --> maint

  %% =======================
  %% Auth / Threads
  %% =======================
  auth --> pg
  threadAPI --> pg

  %% =======================
  %% Chat pipeline (SSE)
  %% =======================
  chatAPI -->|写入 user chat_message + 更新 thread.updated_at| pg
  chatAPI -->|读取 thread_state| tstate
  tstate -->|read| pg

  chatAPI --> guards --> ctx
  ctx -->|读取 users/profile/persona/decision| pg
  ctx -->|memory 向量召回| dashEmb --> qdr

  ctx --> router
  router -->|LLM JSON| ark

  %% =======================
  %% Tool decisions
  %% =======================
  router -->|use_rag| ragTool
  router -->|use_web + enabled + 有 Bing Key| webTool
  router -->|complex -> deep thinking| deep --> roles

  %% =======================
  %% RAG (Qdrant)
  %% =======================
  ragTool -->|embed query| dashEmb
  ragTool -->|vector search| qdr
  ragTool -->|optional rerank（doc>=threshold）| ark
  ark -->|rerank order| ragTool
  ragTool -->|hits| roles
  ragTool -->|hits| synth

  %% =======================
  %% Web search (summary only)
  %% =======================
  webTool -->|queries| bing
  bing -->|title/snippet/url| webTool
  webTool -->|summaries| roles
  webTool -->|summaries| synth

  %% =======================
  %% Deep thinking (fixed roles)
  %% =======================
  roles -->|role JSON outputs| ark
  roles --> synth

  %% =======================
  %% Trace (transparency/debug)
  %% =======================
  chatAPI -->|创建 trace（router/web/deep/roles）| traceTbl
  synth -->|写入 assistant chat_message| pg
  synth -->|更新 trace（assistant_message_id/error）| traceTbl
  traceAPI --> traceTbl
  msgAPI --> pg

  %% =======================
  %% Stream back to UI
  %% =======================
  chatAPI -->|SSE meta：状态/阶段/深度模式| ui
  synth -->|SSE delta：文本流式输出| ui

  %% =======================
  %% Background tasks
  %% =======================
  synth --> bg
  bg -->|记忆抽取/画像刷新/线程状态刷新| ark --> pg
  bg -->|记忆向量写入| dashEmb --> qdr

  %% =======================
  %% Vision
  %% =======================
  visionAPI --> dashVision --> visionAPI
  visionAPI -->|vision_json| ui

  %% =======================
  %% Knowledge ingest / teaching
  %% =======================
  ingestAPI -->|语义分点（知识点）| ark
  ingestAPI -->|embedding| dashEmb --> qdr
  ingestAPI -->|数据源/审核记录| pg
  adminAPI -->|审批 Teaching -> 写入 teaching seeds| qdr

  %% =======================
  %% Admin config + audit + insights
  %% =======================
  adminAPI --> appcfg --> pg
  adminAPI -->|审计（只增不改）| audit --> pg
  adminAPI -->|生成/查看 Trace Insights| insightTbl --> pg

  %% =======================
  %% Maintenance
  %% =======================
  maint -->|刷新 Decision Profile（>=5天）| ark --> pg
  maint -->|清理过期 trace（>30天）| traceTbl
  maint -->|生成 Trace Insights（每天一次）| traceLearn --> insightTbl
